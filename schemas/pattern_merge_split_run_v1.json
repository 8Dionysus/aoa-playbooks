{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/schemas/pattern_merge_split_run_v1.json",
  "title": "pattern_merge_split_run_v1",
  "type": "object",
  "required": [
    "schema_version",
    "kind",
    "id",
    "status",
    "summary",
    "evidence_refs",
    "payload",
    "owner_repo"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "kind": {
      "type": "string",
      "const": "pattern_merge_split_run"
    },
    "id": {
      "type": "string",
      "minLength": 3
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "captured",
        "candidate",
        "review",
        "approved",
        "blocked",
        "rejected",
        "promoted",
        "active",
        "retired",
        "scheduled",
        "passed",
        "failed"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "owner_repo": {
      "type": "string"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "payload": {
      "type": "object",
      "required": [
        "source_patterns",
        "action"
      ],
      "additionalProperties": false,
      "properties": {
        "source_patterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "action": {
          "type": "string"
        }
      }
    }
  },
  "additionalProperties": false
}
