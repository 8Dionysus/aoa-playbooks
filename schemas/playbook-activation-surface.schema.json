{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/8Dionysus/aoa-playbooks/main/schemas/playbook-activation-surface.schema.json",
  "title": "AoA playbook activation surface",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "surface_type",
    "playbook_id",
    "name",
    "scenario",
    "trigger",
    "participating_agents",
    "required_skill_families",
    "expected_artifacts",
    "evaluation_posture",
    "memory_posture",
    "fallback_mode"
  ],
  "properties": {
    "surface_type": {
      "type": "string",
      "const": "playbook_activation_surface"
    },
    "playbook_id": {
      "type": "string",
      "minLength": 3
    },
    "name": {
      "type": "string",
      "minLength": 3
    },
    "scenario": {
      "type": "string",
      "minLength": 3
    },
    "trigger": {
      "type": "string",
      "minLength": 3
    },
    "participating_agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "required_skill_families": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "expected_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "evaluation_posture": {
      "type": "string",
      "enum": [
        "minimal",
        "required",
        "strict",
        "paired_eval"
      ]
    },
    "memory_posture": {
      "type": "string",
      "enum": [
        "none",
        "light_recall",
        "bounded_recall",
        "deep_recall"
      ]
    },
    "fallback_mode": {
      "type": "string",
      "enum": [
        "none",
        "handoff",
        "rollback",
        "safe_stop",
        "review_required"
      ]
    },
    "eval_anchors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    }
  }
}
