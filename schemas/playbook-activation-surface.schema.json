{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/8Dionysus/aoa-playbooks/main/schemas/playbook-activation-surface.schema.json",
  "title": "AoA playbook activation surface",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "surface_type",
    "playbook_id",
    "name",
    "scenario",
    "trigger",
    "participating_agents",
    "required_skill_families",
    "expected_artifacts",
    "evaluation_posture",
    "memory_posture",
    "fallback_mode"
  ],
  "properties": {
    "surface_type": {
      "type": "string",
      "const": "playbook_activation_surface"
    },
    "playbook_id": {
      "type": "string",
      "minLength": 3
    },
    "name": {
      "type": "string",
      "minLength": 3
    },
    "scenario": {
      "type": "string",
      "minLength": 3
    },
    "trigger": {
      "type": "string",
      "minLength": 3
    },
    "participating_agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "required_skill_families": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "expected_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "evaluation_posture": {
      "type": "string",
      "enum": [
        "minimal",
        "required",
        "strict",
        "paired_eval"
      ]
    },
    "memory_posture": {
      "type": "string",
      "enum": [
        "none",
        "light_recall",
        "bounded_recall",
        "deep_recall"
      ]
    },
    "fallback_mode": {
      "type": "string",
      "enum": [
        "none",
        "handoff",
        "rollback",
        "safe_stop",
        "review_required"
      ]
    },
    "eval_anchors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "return_posture": {
      "type": "string",
      "enum": [
        "artifact_anchor",
        "checkpoint_anchor",
        "review_anchor",
        "mixed_anchor"
      ]
    },
    "return_anchor_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "return_reentry_modes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "same_phase",
          "previous_phase",
          "router_reentry",
          "checkpoint_relaunch",
          "review_gate",
          "rollback_gate",
          "safe_stop"
        ]
      }
    },
    "memo_recall_modes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "working",
          "episodic",
          "semantic",
          "procedural",
          "lineage"
        ]
      }
    },
    "memo_scope_default": {
      "type": "string",
      "enum": [
        "project",
        "workspace",
        "ecosystem"
      ]
    },
    "memo_scope_ceiling": {
      "type": "string",
      "enum": [
        "project",
        "workspace",
        "ecosystem"
      ]
    },
    "memo_read_path": {
      "type": "string",
      "enum": [
        "inspect_only",
        "inspect_then_expand",
        "inspect_capsule_then_expand"
      ]
    },
    "memo_checkpoint_posture": {
      "type": "string",
      "enum": [
        "not_needed",
        "preferred",
        "required"
      ]
    },
    "memo_source_route_policy": {
      "type": "string",
      "enum": [
        "not_needed",
        "preferred",
        "required"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "required": [
          "return_posture"
        ]
      },
      "then": {
        "required": [
          "return_anchor_artifacts",
          "return_reentry_modes"
        ]
      }
    },
    {
      "if": {
        "required": [
          "return_anchor_artifacts"
        ]
      },
      "then": {
        "required": [
          "return_posture"
        ]
      }
    },
    {
      "if": {
        "required": [
          "return_reentry_modes"
        ]
      },
      "then": {
        "required": [
          "return_posture"
        ]
      }
    }
  ]
}
