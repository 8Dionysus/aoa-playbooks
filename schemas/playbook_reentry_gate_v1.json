{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/aoa-playbooks/schemas/playbook_reentry_gate_v1.json",
  "title": "playbook_reentry_gate_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "gate_id",
    "generated_at_utc",
    "playbook_id",
    "scope",
    "required_evidence",
    "readiness_checks",
    "decision",
    "decided_by"
  ],
  "$defs": {
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "target",
        "pass_condition"
      ],
      "properties": {
        "kind": {
          "enum": [
            "receipt",
            "eval",
            "validator",
            "operator",
            "artifact"
          ]
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "pass_condition": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "properties": {
    "schema_version": {
      "const": "playbook_reentry_gate_v1"
    },
    "gate_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "playbook_id": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo",
        "stress_family"
      ],
      "properties": {
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "surface": {
          "type": [
            "string",
            "null"
          ]
        },
        "stress_family": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "required_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "readiness_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/check"
      }
    },
    "decision": {
      "enum": [
        "resume",
        "resume_degraded",
        "hold",
        "retire_route"
      ]
    },
    "decided_by": {
      "type": "string",
      "minLength": 1
    },
    "reopen_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
