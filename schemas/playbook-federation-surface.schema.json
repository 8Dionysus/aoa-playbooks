{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/8Dionysus/aoa-playbooks/main/schemas/playbook-federation-surface.schema.json",
  "title": "AoA playbook federation surface",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "surface_type",
    "playbook_id",
    "name",
    "participating_agents",
    "memory_posture",
    "required_skills",
    "memo_contract_refs",
    "memo_writeback_targets"
  ],
  "properties": {
    "surface_type": {
      "type": "string",
      "const": "playbook_federation_surface"
    },
    "playbook_id": {
      "type": "string",
      "minLength": 3
    },
    "name": {
      "type": "string",
      "minLength": 3
    },
    "participating_agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "memory_posture": {
      "type": "string",
      "enum": [
        "none",
        "light_recall",
        "bounded_recall",
        "deep_recall",
        "bounded_chronicle_candidate_only"
      ]
    },
    "required_skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "eval_anchors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "memo_contract_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "memo_writeback_targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "memo_recall_modes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "working",
          "episodic",
          "semantic",
          "procedural",
          "lineage"
        ]
      }
    },
    "memo_scope_default": {
      "type": "string",
      "enum": [
        "project",
        "workspace",
        "ecosystem"
      ]
    },
    "memo_scope_ceiling": {
      "type": "string",
      "enum": [
        "project",
        "workspace",
        "ecosystem"
      ]
    },
    "memo_read_path": {
      "type": "string",
      "enum": [
        "inspect_only",
        "inspect_then_expand",
        "inspect_capsule_then_expand"
      ]
    },
    "memo_checkpoint_posture": {
      "type": "string",
      "enum": [
        "not_needed",
        "preferred",
        "required"
      ]
    },
    "memo_source_route_policy": {
      "type": "string",
      "enum": [
        "not_needed",
        "preferred",
        "required"
      ]
    }
  }
}
