{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://8dionysus.github.io/schemas/questline_outline_v1.schema.json",
  "title": "questline_outline_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "title",
    "campaign_kind",
    "entry_quest",
    "recommended_cohort_pattern",
    "stages",
    "reanchor_policy",
    "harvest_policy",
    "public_safe"
  ],
  "properties": {
    "schema_version": {
      "const": "questline_outline_v1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 5
    },
    "summary": {
      "type": "string"
    },
    "campaign_kind": {
      "type": "string",
      "enum": [
        "questline",
        "campaign",
        "raid"
      ]
    },
    "entry_quest": {
      "type": "string",
      "minLength": 1
    },
    "recommended_cohort_pattern": {
      "type": "string",
      "minLength": 1
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "stage_id",
          "quest_ref",
          "anchor_class",
          "success_signal"
        ],
        "properties": {
          "stage_id": {
            "type": "string",
            "minLength": 1
          },
          "quest_ref": {
            "type": "string",
            "minLength": 1
          },
          "anchor_class": {
            "type": "string",
            "enum": [
              "artifact_anchor",
              "checkpoint_anchor",
              "review_anchor"
            ]
          },
          "success_signal": {
            "type": "string",
            "minLength": 1
          },
          "note": {
            "type": "string"
          }
        }
      }
    },
    "reanchor_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_reanchors",
        "valid_anchor_classes",
        "rule"
      ],
      "properties": {
        "max_reanchors": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        },
        "valid_anchor_classes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "artifact_anchor",
              "checkpoint_anchor",
              "review_anchor"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "rule": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "harvest_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min_reviewed_lanes",
        "promotion_target"
      ],
      "properties": {
        "min_reviewed_lanes": {
          "type": "integer",
          "minimum": 0
        },
        "promotion_target": {
          "type": "string",
          "enum": [
            "none",
            "playbook",
            "skill",
            "eval",
            "technique",
            "agent_contract",
            "memo"
          ]
        },
        "note": {
          "type": "string"
        }
      }
    },
    "public_safe": {
      "type": "boolean"
    }
  }
}
