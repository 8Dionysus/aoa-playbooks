{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-playbooks/schemas/playbook-registry.schema.json",
  "title": "AoA playbook registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "layer", "playbooks"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "layer": {
      "type": "string",
      "const": "aoa-playbooks"
    },
    "playbooks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "status",
          "summary",
          "scenario",
          "trigger",
          "prerequisites",
          "participating_agents",
          "required_skill_families",
          "evaluation_posture",
          "memory_posture",
          "fallback_mode",
          "expected_artifacts"
        ],
        "properties": {
          "id": {"type": "string", "minLength": 3},
          "name": {"type": "string", "minLength": 3},
          "status": {"type": "string", "enum": ["active", "planned", "experimental", "deprecated"]},
          "summary": {"type": "string", "minLength": 10},
          "scenario": {"type": "string", "minLength": 3},
          "trigger": {"type": "string", "minLength": 3},
          "prerequisites": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 2}},
          "participating_agents": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 2}},
          "required_skill_families": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 2}},
          "evaluation_posture": {"type": "string", "enum": ["minimal", "required", "strict", "paired_eval"]},
          "memory_posture": {"type": "string", "enum": ["none", "light_recall", "bounded_recall", "deep_recall"]},
          "fallback_mode": {"type": "string", "enum": ["none", "handoff", "rollback", "safe_stop", "review_required"]},
          "expected_artifacts": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 2}},
          "eval_anchors": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 3}},
          "return_posture": {
            "type": "string",
            "enum": ["artifact_anchor", "checkpoint_anchor", "review_anchor", "mixed_anchor"]
          },
          "return_anchor_artifacts": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 2}
          },
          "return_reentry_modes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": ["same_phase", "previous_phase", "router_reentry", "checkpoint_relaunch", "review_gate", "rollback_gate", "safe_stop"]
            }
          }
        },
        "allOf": [
          {
            "if": {
              "required": ["return_posture"]
            },
            "then": {
              "required": ["return_anchor_artifacts", "return_reentry_modes"]
            }
          },
          {
            "if": {
              "required": ["return_anchor_artifacts"]
            },
            "then": {
              "required": ["return_posture"]
            }
          },
          {
            "if": {
              "required": ["return_reentry_modes"]
            },
            "then": {
              "required": ["return_posture"]
            }
          }
        ]
      }
    }
  }
}
