{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/8Dionysus/aoa-playbooks/main/schemas/playbook-review-status.schema.json",
  "title": "AoA playbook review status surface",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "layer",
    "source_of_truth",
    "playbooks"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "layer": {
      "type": "string",
      "const": "aoa-playbooks"
    },
    "source_of_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reviewed_runs_dir",
        "gate_reviews_dir"
      ],
      "properties": {
        "reviewed_runs_dir": {
          "type": "string",
          "const": "docs/real-runs"
        },
        "gate_reviews_dir": {
          "type": "string",
          "const": "docs/gate-reviews"
        }
      }
    },
    "playbooks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "playbook_id",
          "playbook_name",
          "scenario",
          "gate_review_ref",
          "reviewed_run_count",
          "reviewed_run_refs",
          "minimum_evidence_threshold",
          "gate_verdict",
          "next_trigger",
          "composition_signal_summary"
        ],
        "properties": {
          "playbook_id": {
            "type": "string",
            "pattern": "^AOA-P-[0-9]{4}$"
          },
          "playbook_name": {
            "type": "string",
            "minLength": 3
          },
          "scenario": {
            "type": "string",
            "minLength": 3
          },
          "gate_review_ref": {
            "type": "string",
            "pattern": "^docs/gate-reviews/[a-z0-9-]+\\.md$"
          },
          "reviewed_run_count": {
            "type": "integer",
            "minimum": 0
          },
          "reviewed_run_refs": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^docs/real-runs/[0-9]{4}-[0-9]{2}-[0-9]{2}\\.[a-z0-9-]+\\.md$"
            }
          },
          "latest_reviewed_run_ref": {
            "type": [
              "string",
              "null"
            ],
            "pattern": "^docs/real-runs/[0-9]{4}-[0-9]{2}-[0-9]{2}\\.[a-z0-9-]+\\.md$"
          },
          "minimum_evidence_threshold": {
            "type": "string",
            "minLength": 10
          },
          "gate_verdict": {
            "type": "string",
            "enum": [
              "hold",
              "ready-for-composition-review",
              "composition-landed"
            ]
          },
          "next_trigger": {
            "type": "string",
            "minLength": 10
          },
          "composition_signal_summary": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "failure_or_follow_up",
              "adjunct_candidate"
            ],
            "properties": {
              "failure_or_follow_up": {
                "type": "string",
                "minLength": 10
              },
              "adjunct_candidate": {
                "type": "string",
                "minLength": 10
              }
            }
          }
        }
      }
    }
  }
}
