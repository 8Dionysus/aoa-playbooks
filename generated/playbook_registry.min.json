{
  "version": 1,
  "layer": "aoa-playbooks",
  "playbooks": [
    {
      "id": "AOA-P-0001",
      "name": "repo-bootstrap",
      "status": "active",
      "summary": "Bootstraps a new repository or layer with bounded scaffolding, docs, validation, and contributor guidance.",
      "scenario": "repo_bootstrap",
      "trigger": "new_layer_or_repo",
      "prerequisites": ["clear_repo_role"],
      "participating_agents": ["architect", "coder", "reviewer"],
      "required_skill_families": ["change-protocol", "verification", "architecture"],
      "evaluation_posture": "required",
      "memory_posture": "light_recall",
      "fallback_mode": "review_required",
      "expected_artifacts": ["README", "CHARTER", "ROADMAP", "validator"]
    },
    {
      "id": "AOA-P-0002",
      "name": "safe-change-rollout",
      "status": "active",
      "summary": "Coordinates a bounded change with explicit validation, review posture, and fallback handling.",
      "scenario": "safe_change",
      "trigger": "bounded_change_request",
      "prerequisites": ["scoped_task"],
      "participating_agents": ["coder", "reviewer"],
      "required_skill_families": ["change-protocol", "verification", "review"],
      "evaluation_posture": "strict",
      "memory_posture": "light_recall",
      "fallback_mode": "rollback",
      "expected_artifacts": ["diff", "verification_report", "review_notes"]
    },
    {
      "id": "AOA-P-0003",
      "name": "bounded-research-pass",
      "status": "active",
      "summary": "Runs a constrained research or exploration pass with explicit questions, synthesis, and next-step artifacts.",
      "scenario": "bounded_research",
      "trigger": "research_need",
      "prerequisites": ["bounded_question"],
      "participating_agents": ["architect", "reviewer"],
      "required_skill_families": ["research", "synthesis", "boundary-checks"],
      "evaluation_posture": "required",
      "memory_posture": "bounded_recall",
      "fallback_mode": "safe_stop",
      "expected_artifacts": ["research_summary", "decision_notes", "next_steps"]
    },
    {
      "id": "AOA-P-0004",
      "name": "release-prep",
      "status": "active",
      "summary": "Prepares a repository or layer for merge or release with bounded checks, summaries, and merge posture.",
      "scenario": "release_prep",
      "trigger": "merge_or_release_window",
      "prerequisites": ["candidate_changes_present"],
      "participating_agents": ["reviewer", "evaluator"],
      "required_skill_families": ["review", "evaluation", "release-prep"],
      "evaluation_posture": "strict",
      "memory_posture": "light_recall",
      "fallback_mode": "review_required",
      "expected_artifacts": ["merge_readiness_notes", "summary", "validation_output"]
    },
    {
      "id": "AOA-P-0005",
      "name": "memory-curation-pass",
      "status": "active",
      "summary": "Curates bounded memory outputs from scattered inputs while keeping memory distinct from proof and execution.",
      "scenario": "memory_curation",
      "trigger": "memory_cleanup_or_capture",
      "prerequisites": ["candidate_memory_inputs"],
      "participating_agents": ["memory-keeper", "reviewer"],
      "required_skill_families": ["memory-curation", "provenance", "review"],
      "evaluation_posture": "required",
      "memory_posture": "deep_recall",
      "fallback_mode": "handoff",
      "expected_artifacts": ["curated_memory_output", "provenance_notes"]
    },
    {
      "id": "AOA-P-0006",
      "name": "self-agent-checkpoint-rollout",
      "status": "experimental",
      "summary": "Coordinates a bounded self-agent or policy-sensitive change through approval, rollback, health checks, and an improvement log.",
      "scenario": "self_agent_checkpoint",
      "trigger": "self_change_or_policy_sensitive_change",
      "prerequisites": ["constitution_or_source_of_truth_check_defined", "approval_gate_defined", "rollback_marker_available", "health_check_defined"],
      "participating_agents": ["architect", "coder", "reviewer", "memory-keeper"],
      "required_skill_families": ["source-of-truth", "approval-gate", "change-protocol", "memory-curation"],
      "evaluation_posture": "strict",
      "memory_posture": "bounded_recall",
      "fallback_mode": "rollback",
      "expected_artifacts": ["approval_record", "rollback_marker", "health_check", "improvement_log"]
    }
  ]
}
